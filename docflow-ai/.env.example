# ─── DocFlow AI — Environment Variables ───────────────────────────────────────
# Copy this to .env and customize

# Ollama: which model to use for extraction
# Options: qwen2.5:7b | mistral:7b | llama3.2:3b | llama3.1:8b
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120

# Qdrant vector store
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Confidence scoring
# Below this threshold → flagged for human review
CONFIDENCE_THRESHOLD=0.75

# Optional: push results to your existing system
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://your-system.com/api/invoices/inbound

# File storage
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
MAX_FILE_SIZE_MB=20

# Docker Compose: n8n credentials
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=docflow123
